# Non-secret local config only. Real secrets live in the host's environment
# store (Render) or AWS Secrets Manager — never in this file, never committed.
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Local docker-compose Postgres (throwaway dev credentials, not a secret).
# Must be a Postgres with PostGIS available: the first migration runs
# CREATE EXTENSION postgis and the app uses geography columns throughout.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/letscycle

# Only needed behind a transaction-mode connection pooler (e.g. Supabase).
# Migrations cannot run through the pooler, so they use this direct connection
# while the server keeps the pooled DATABASE_URL. Leave unset locally.
DIRECT_DATABASE_URL=

# Signs dummy-Cognito dev tokens AND is the HMAC key for stored dev passwords.
# Changing it invalidates every session and locks out every existing account —
# generate once per environment and leave it alone. Minimum 16 characters.
AUTH_DEV_TOKEN_SECRET=

# Browser origin allowed by CORS (the deployed frontend URL). Unset locally so
# any dev origin is reflected; always set it in a deployed environment.
FRONTEND_ORIGIN=

# Browser-reachable origin of this API. Used to build dev upload URLs, so it
# must be the public URL in a deployed environment.
PUBLIC_API_ORIGIN=

# Google OAuth Client ID (Web) — enables "Continue with Google".
# Must match the client's NEXT_PUBLIC_GOOGLE_CLIENT_ID.
GOOGLE_CLIENT_ID=

# Cloudinary — backs image uploads where the host has no persistent disk.
# Set all three together, or none (which falls back to the local dev media
# store). The API secret signs upload tickets and must never reach the browser.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

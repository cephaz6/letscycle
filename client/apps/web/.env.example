# Base URL of the LetsCycle API, including the /api/v1 version prefix.
# Inlined into the browser bundle at build time (NEXT_PUBLIC_*), so a future
# React Native app can point at a different origin without code changes.
# Defaults to the local backend when unset.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1

# Google OAuth Client ID (Web) — enables "Continue with Google".
# Create one at console.cloud.google.com → Credentials → OAuth client ID (Web),
# with authorized JS origins http://localhost:3001 and http://127.0.0.1:3001.
# Set the SAME value as the backend's GOOGLE_CLIENT_ID. Leave blank to hide it.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Base URL for static assets in public/ (illustrations, etc.). Empty = served
# from the app origin. Set to a CDN/S3 base (e.g. https://cdn.letscycle.app) to
# move assets to cloud storage without code changes.
NEXT_PUBLIC_ASSET_BASE_URL=
